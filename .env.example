# Copy this file to ".env" and fill in your own Supabase project values.
# Find them in: Supabase dashboard → your project → Connect (or Project Settings → API).
# The anon / publishable key is safe for the browser; never put the service_role / secret key here.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-or-publishable-key
